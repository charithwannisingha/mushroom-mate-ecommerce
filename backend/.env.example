# ====== MUSHROOM MATE Backend Environment ======
# මෙම ගොනුව .env ලෙස පිටපත් කර ඔබගේ දත්ත ඇතුළත් කරන්න

PORT=5000

# MySQL දත්ත සමුදාය සැකසුම්
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mushroom_mate

# JWT රහස් යතුර (production හි මෙය වෙනස් කරන්න)
JWT_SECRET=mushroom_mate_super_secret_key_2026
JWT_EXPIRES=7d

# Frontend URL (CORS සඳහා)
CLIENT_URL=http://localhost:5173
